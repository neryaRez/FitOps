{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "src",
    "src/vite-env.d.ts",
    "vite.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
